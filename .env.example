# ---------------------------------------------------------------------------
# RankNex AI — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Database (Prisma + PostgreSQL via Supabase).
# Get both from Supabase: Project Settings -> Database -> Connection string.
#
# DATABASE_URL  = "Transaction" pooler (port 6543) + ?pgbouncer=true  (app runtime)
# DIRECT_URL    = "Session"/"Direct" connection (port 5432)           (migrations)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# NextAuth — secret used to sign session/JWT tokens. REQUIRED in production.
# Generate a strong value:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-strong-secret"

# Canonical site URL. Local: http://localhost:3000 — Production: your domain.
NEXTAUTH_URL="http://localhost:3000"

# Admin login password used by the seed script (prisma/seed.ts). Set your own,
# then run `npm run db:seed` to (re)set it. Username is "admin".
ADMIN_PASSWORD="change-me"

# ---------------------------------------------------------------------------
# Supabase Storage (image/video uploads). From Supabase: Project Settings ->
# API. The service role key is SECRET — server-side only, never expose it.
# Create a PUBLIC storage bucket (default name "media") under Storage.
# ---------------------------------------------------------------------------
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="media"
