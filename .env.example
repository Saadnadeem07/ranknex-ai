# ---------------------------------------------------------------------------
# RankNex AI — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Database (Prisma). SQLite by default for local development.
# For production, use a hosted DB (e.g. Postgres) and update the `provider`
# in prisma/schema.prisma to match.
DATABASE_URL="file:./dev.db"

# NextAuth — secret used to sign session/JWT tokens.
# Generate a strong value:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-strong-secret"

# Canonical site URL. Used for auth callbacks, sitemap and OG/Schema tags.
# In production set this to your real domain, e.g. https://ranknexai.com
NEXTAUTH_URL="http://localhost:3000"

# Upload directory (relative to public/)
UPLOAD_DIR="uploads"
