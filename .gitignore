# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# Next.js build output
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# Production
/dist

# Environment variables (never commit secrets)
.env
.env.*
!.env.example

# Prisma / local database
*.db
*.db-journal
prisma/dev.db
prisma/*.db
prisma/migrations/dev.db*

# User uploads (keep the directory, ignore contents)
public/uploads/*
!public/uploads/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing / coverage
/coverage

# Editor & OS files
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# Vercel
.vercel
